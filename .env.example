# === LLM API Keys ===
GOOGLE_API_KEY=your-google-ai-studio-key
GROQ_API_KEY=your-groq-api-key
# HF_TOKEN=your-huggingface-token  # Optional fallback

# === Messaging ===
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# Numeric Telegram user ID allowed to DM the bot (get from @userinfobot)
ALLOWED_TELEGRAM_ID=
# E.164 phone number allowed to DM the bot on WhatsApp, e.g. +91XXXXXXXXXX
ALLOWED_WHATSAPP_NUMBER=

# === Google Sheets Tracker ===
# Relative paths are resolved from the repo root by the setup script
GOOGLE_SERVICE_ACCOUNT_FILE=data/service-account.json

# === Web UI ===
JOBPILOT_WEB_TOKEN=change-this-to-a-random-string
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# === OpenClaw Gateway ===
OPENCLAW_GATEWAY_URL=http://localhost:18789
# Optional: set to pin the gateway auth token across regenerations.
# If unset, tools/setup_openclaw_config.py generates a fresh random token each run.
OPENCLAW_GATEWAY_TOKEN=
